{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Dev Server",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev -- --host",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "name": "Debug React App (Attach)",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}/src",
      "sourceMapPathOverrides": {
        "webpack:///src/*": "${webRoot}/*"
      }
    },
    {
      "name": "Debug Vitest Tests",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run test:run -- --reporter=verbose",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug Current Vitest Test",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run test:run -- ${file} --reporter=verbose",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
